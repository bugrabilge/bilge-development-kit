{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.agent/scripts/hooks/dangerous_cmd_check.sh\"",
            "timeout": 10,
            "statusMessage": "Checking for dangerous commands..."
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.agent/scripts/hooks/secret_scanner.sh\"",
            "timeout": 10,
            "statusMessage": "Scanning for secrets..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.agent/scripts/hooks/lint_check.sh\"",
            "timeout": 30,
            "statusMessage": "Running lint check..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.agent/scripts/hooks/session_save.sh\"",
            "timeout": 15,
            "statusMessage": "Saving session context..."
          }
        ]
      }
    ]
  }
}
